icalAlign":"top","baseline":12,"containerId":null,"originalText":"[ cover image ]","lineHeight":1.25,"autoResize":true},{"id":"el-02107","type":"text","x":1752,"y":5636,"width":142,"height":22.5,"angle":0,"strokeColor":"#0f172a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1081625049,"version":1,"versionNonce":30812553,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"The 2022 shift","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":16,"containerId":null,"originalText":"The 2022 shift","lineHeight":1.25,"autoResize":true},{"id":"el-02108","type":"text","x":1752,"y":5668,"width":892,"height":16,"angle":0,"strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":136336945,"version":1,"versionNonce":490191739,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"In early 2022, something unexpected happened in the note-taking market. For years, Notion had been the dominant player — a beautifully-designed, VC-funded, all-in-one workspace that absorbed productivity tools one by one…","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"In early 2022, something unexpected happened in the note-taking market. For years, Notion had been the dominant player — a beautifully-designed, VC-funded, all-in-one workspace that absorbed productivity tools one by one…","lineHeight":1.25,"autoResize":true},{"id":"el-02109","type":"text","x":1752,"y":5724,"width":892,"height":16,"angle":0,"strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":943951211,"version":1,"versionNonce":61625303,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"But underneath the surface, a different movement was gathering. Obsidian, a scrappy indie tool built by a two-person team in Toronto, was quietly winning over knowledge workers, academics, and developers…","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"But underneath the surface, a different movement was gathering. Obsidian, a scrappy indie tool built by a two-person team in Toronto, was quietly winning over knowledge workers, academics, and developers…","lineHeight":1.25,"autoResize":true},{"id":"el-02110","type":"text","x":1752,"y":5780,"width":132,"height":22.5,"angle":0,"strokeColor":"#0f172a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1867693558,"version":1,"versionNonce":1051965577,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"Notion's moat","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":16,"containerId":null,"originalText":"Notion's moat","lineHeight":1.25,"autoResize":true},{"id":"el-02111","type":"text","x":1752,"y":5812,"width":892,"height":16,"angle":0,"strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":228617538,"version":1,"versionNonce":776727669,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"Notion's early success came from a key insight: content should be structured like a database but read like a document. Blocks, relations, filters — these were primitives powerful enough to build anything…","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"Notion's early success came from a key insight: content should be structured like a database but read like a document. Blocks, relations, filters — these were primitives powerful enough to build anything…","lineHeight":1.25,"autoResize":true},{"id":"el-02112","type":"rectangle","x":1752,"y":5868,"width":4,"height":40,"angle":0,"strokeColor":"#0ea5e9","backgroundColor":"#0ea5e9","fillStyle":"solid","strokeWidth":0,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1842223307,"version":1,"versionNonce":1305935427,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false},{"id":"el-02113","type":"text","x":1768,"y":5872,"width":872,"height":17,"angle":0,"strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1054966639,"version":1,"versionNonce":1144157814,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"\"Obsidian feels like a personal extension of your mind. Notion feels like a team tool that happens to support individuals.\" — Cory Wilkerson, 2023","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"\"Obsidian feels like a personal extension of your mind. Notion feels like a team tool that happens to support individuals.\" — Cory Wilkerson, 2023","lineHeight":1.25,"autoResize":true},{"id":"el-02114","type":"text","x":1752,"y":5928,"width":892,"height":16,"angle":0,"strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":673141780,"version":1,"versionNonce":835436983,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false,"text":"The crack in Notion's armor wasn't features. It was speed, ownership, and the vibes of indie software. Obsidian was fast, local-first, file-based…","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"The crack in Notion's armor wasn't features. It was speed, ownership, and the vibes of indie software. Obsidian was fast, local-first, file-based…","lineHeight":1.25,"autoResize":true},{"id":"el-02115","type":"rectangle","x":2662,"y":5219,"width":500,"height":200,"angle":0,"strokeColor":"#00000008","backgroundColor":"#00000008","fillStyle":"solid","strokeWidth":0,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3,"value":12},"seed":1489148769,"version":1,"versionNonce":1254348339,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false},{"id":"el-02116","type":"rectangle","x":2660,"y":5216,"width":500,"height":200,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":1.5,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3,"value":12},"seed":1227001789,"version":1,"versionNonce":167580404,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false},{"id":"el-02117","type":"rectangle","x":2676,"y":5232,"width":4,"height":24,"angle":0,"strokeColor":"#0ea5e9","backgroundColor":"#0ea5e9","fillStyle":"solid","strokeWidth":0,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":1397268111,"version":1,"versionNonce":127660922,"isDeleted":false,"boundElements":[],"updated":1775719727267,"link":null,"locked":false},{"id":"el-02118","type":"text","x":2688,"y":5232,"width":168,"height":19,"angle":0,"strokeColor":"#0f172a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.5,"strokeStyl